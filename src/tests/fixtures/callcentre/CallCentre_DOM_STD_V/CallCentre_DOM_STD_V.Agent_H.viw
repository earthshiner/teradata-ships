
REPLACE VIEW CallCentre_DOM_STD_V.Agent_H
(
      agent_id
    , agent_key
    , agent_name
    , source_agent_name
    , valid_from_dts
    , valid_to_dts
    , is_current
    , is_deleted
)
AS
LOCKING ROW FOR ACCESS
SELECT
      agent_id
    , agent_key
    , agent_name
    , source_agent_name
    , valid_from_dts
    , valid_to_dts
    , is_current
    , is_deleted
FROM CallCentre_DOM_STD_T.Agent_H;
