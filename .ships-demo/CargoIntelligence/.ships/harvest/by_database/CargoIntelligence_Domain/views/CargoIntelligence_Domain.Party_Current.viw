REPLACE VIEW {{CargoIntelligence_Domain_V}}.Party_Current (
    party_id,
    party_key,
    party_name,
    source_system,
    source_key,
    valid_from_dt,
    valid_to_dt
)
AS
SELECT
    pc.party_id,
    pc.party_key,
    pc.party_name,
    pc.source_system,
    pc.source_key,
    pc.valid_from_dt,
    pc.valid_to_dt
FROM {{CargoIntelligence_Domain_T}}.{{Party_H_V}} pc
WHERE pc.is_current = 1
  AND pc.is_deleted = 0;