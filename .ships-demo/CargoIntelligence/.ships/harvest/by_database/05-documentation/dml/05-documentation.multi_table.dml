-- BUSINESS_GLOSSARY -- 4 rows
-- -----------------------------------------------------------------------------

INSERT INTO CargoIntelligence_Memory.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Vector Embedding',
    'ATTRIBUTE',
    'A dense numerical representation of text or structured data as a fixed-length array of floating-point numbers. Generated by a machine learning model (bge-{{small_T}}-en-v1.5 in CargoIntelligence). Semantically similar texts produce vectors that are close together in vector space, enabling similarity search via cosine distance.',
    'CargoIntelligence generates 384-dimension embeddings stored as VARBYTE(1536) using {{mldb_V}}.{{ONNXEmbeddings_T}} with bge-{{small_T}}-en-v1.5 (OutputFormat VARBYTE(1536), ModelOutputTensor sentence_embedding). {{TD_VectorDistance_T}} accepts VARBYTE columns natively for cosine similarity -- no CAST required.',
    'Embedding, dense vector, semantic vector',
    'Cosine Similarity, Feature Text, Risk Profile Anchor',
    'CargoIntelligence_Search.entity_embedding',
    'embedding_vector',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Cosine Similarity',
    'METRIC',
    'A measure of similarity between two vectors calculated as the cosine of the angle between them. Range: -1 (opposite) to 1 (identical). Values close to 1 mean the two texts are semantically similar. TD_VectorDistance returns cosine distance (1 minus cosine similarity), so lower distance equals higher similarity.',
    'CargoIntelligence uses cosine similarity to score each consignment against 8 risk profile archetypes. similarity_score_max equals 1 minus MIN(cosine_distance) across all 8 profiles. A score near 1.0 means the consignment strongly resembles a risk archetype. High similarity to RP-008 (LEGITIMATE baseline) is a negative risk signal.',
    'Cosine distance, angular similarity',
    'Vector Embedding, similarity_score_max, TD_VectorDistance',
    'CargoIntelligence_Prediction.consignment_features',
    'similarity_score_max',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Feature Text (Search)',
    'ATTRIBUTE',
    'A structured string encoding of key risk attributes for a consignment or risk profile, used as the input to the ONNX embedding model. Format: HS{chapter} {origin_risk_tier} {transport_code} {vpk_band}. Example: HS24 HIGH AIR_MAIL LOW. Makes similarity structural -- two consignments with the same HS chapter, origin tier, transport mode, and value density band will have near-identical embeddings.',
    'The feature_text construction is the core design choice that makes CargoIntelligence similarity search meaningful. The format must be identical between consignment feature_text (constructed at ETL time from {{Consignment_Enriched_T}}) and risk profile feature_text (stored in RiskProfile_R). vpk_band thresholds: VERY_LOW below 1.00, LOW 1.00 to 3.50, MEDIUM 3.51 to 10.00, HIGH above 10.00.',
    'Feature string, embedding input, risk encoding',
    'Vector Embedding, Risk Profile Anchor, value_per_kg',
    '{{CargoIntelligence_Search_T}}.{{entity_embedding_T}}',
    'feature_text',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO CargoIntelligence_Memory.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Risk Profile Anchor',
    'BUSINESS_RULE',
    'One of the 8 curated smuggling archetypes ({{rp_T}}-001 through {{rp_T}}-008) whose embeddings serve as reference points for {{TD_VectorDistance_T}} similarity scoring. Each consignment embedding is scored against all 8 anchor embeddings. The highest similarity score determines which archetype the consignment most resembles. {{rp_T}}-008 (LEGITIMATE baseline) is the only non-risk anchor, serving as the negative reference.',
    'Risk profile anchors are stored in {{entity_embedding_T}} with {{entity_type_T}} = RISK_PROFILE. They are embedded once at Search module load and remain static until new archetypes are added or the model is changed. The Prediction module uses {{TD_VectorDistance_T}} against these 8 anchors to compute similarity_score_max for every consignment.',
    'Archetype anchor, reference embedding, profile vector',
    'RiskProfile_R, Feature Text (Search), Cosine Similarity',
    '{{CargoIntelligence_Domain_T}}.RiskProfile_R',
    'feature_text',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

-- -----------------------------------------------------------------------------
-- QUERY_COOKBOOK -- 3 rows
-- -----------------------------------------------------------------------------

INSERT INTO CargoIntelligence_Memory.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEARCH-001',
    'Score a single consignment against all 8 risk profile anchors',
    'Retrieves the cosine distance between one consignment and all 8 risk profile anchor embeddings using TD_VectorDistance. Returns one row per profile ordered by distance ascending (most similar first). similarity_score = 1 - distance. Use for investigating why a specific consignment received a high or low composite risk score.',
    'Analyst investigation, similarity scoring explainability, model validation',
    'SEARCH',
    'SELECT {{rp_V}}.profile_code, {{rp_V}}.profile_name, {{rp_V}}.profile_category, CAST(1.0 - dt.distance AS DECIMAL(10,6)) AS similarity_score, dt.distance AS cosine_distance FROM {{TD_VectorDistance_T}}(ON (SELECT entity_id, embedding_vector FROM {{CargoIntelligence_Search_T}}.{{entity_embedding_T}} WHERE entity_id = [{{consignment_id_T}}] AND {{entity_type_T}} = CONSIGNMENT AND is_current = 1) AS TargetTable PARTITION BY ANY ON (SELECT entity_id, embedding_vector FROM {{CargoIntelligence_Search_T}}.{{entity_embedding_T}} WHERE {{entity_type_T}} = RISK_PROFILE AND is_current = 1) AS ReferenceTable DIMENSION USING TargetIDColumn(entity_id) TargetFeatureColumns(embedding_vector) RefIDColumn(entity_id) RefFeatureColumns(embedding_vector) DistanceMeasure(cosine) TopK(8)) AS dt INNER JOIN {{CargoIntelligence_Domain_T}}.RiskProfile_R {{rp_T}} ON {{rp_V}}.risk_profile_id = dt.reference_id ORDER BY dt.distance',
    '[{{consignment_id_T}}] = {{consignment_id_T}} surrogate key from Consignment_H. Returns 8 rows, one per profile, ordered by similarity descending (lowest cosine distance first).',
    '{{TD_VectorDistance_T}} on 1 target vector against 8 reference vectors -- negligible compute.',
    'MODERATE',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEARCH-002',
    'Find consignments most similar to a specific risk profile',
    'Returns the N consignments whose feature_text embedding most closely matches a specific risk profile anchor. Joins to v_consignment_searchable for enriched content. Use for identifying which consignments most closely resemble a known smuggling pattern.',
    'Risk investigation, pattern identification, analyst screening',
    'SEARCH',
    'SELECT cs.consignment_key, cs.declaration_date, cs.trade_value_usd, cs.net_weight_kg, cs.value_per_kg, cs.hs_chapter, cs.origin_risk_tier, cs.transport_code, cs.feature_text, CAST(1.0 - dt.distance AS DECIMAL(10,6)) AS similarity_score FROM TD_VECTORDISTANCE(ON (SELECT entity_id, embedding_vector FROM CargoIntelligence_Search.entity_embedding WHERE entity_id = (SELECT risk_profile_id FROM CargoIntelligence_Domain.RiskProfile_R WHERE profile_code = [profile_code]) AND entity_type = RISK_PROFILE AND is_current = 1) AS TargetTable PARTITION BY ANY ON (SELECT entity_id, embedding_vector FROM CargoIntelligence_Search.entity_embedding WHERE entity_type = CONSIGNMENT AND is_current = 1) AS ReferenceTable DIMENSION USING TargetIDColumn(entity_id) TargetFeatureColumns(embedding_vector) RefIDColumn(entity_id) RefFeatureColumns(embedding_vector) DistanceMeasure(cosine) TopK([top_n])) AS dt INNER JOIN CargoIntelligence_Search.v_consignment_searchable cs ON cs.consignment_id = dt.reference_id ORDER BY dt.distance',
    '[profile_code] = risk profile code e.g. RP-002. [top_n] = number of consignments to return e.g. 100.',
    'TD_VectorDistance on 1 target against 2M reference vectors. Parallel AMP execution but may be slow on small instance. Consider adding pre-filter on entity_type.',
    'MODERATE',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEARCH-003',
    'Embedding coverage check by entity type and model',
    'Returns the count of current embeddings by entity_type and embedding_model. Use after ETL load to confirm expected row counts (8 RISK_PROFILE rows, approximately 2M CONSIGNMENT rows) and to monitor for embedding refresh completeness.',
    'ETL validation, coverage monitoring, data product health check',
    'SEARCH',
    'SELECT ee.entity_type, ee.embedding_model, ee.embedding_dimensions, COUNT(*) AS embedding_cnt, MIN(ee.generated_dts) AS earliest_generated, MAX(ee.generated_dts) AS latest_generated FROM CargoIntelligence_Search.entity_embedding ee WHERE ee.is_current = 1 GROUP BY ee.entity_type, ee.embedding_model, ee.embedding_dimensions ORDER BY ee.entity_type',
    'No parameters. Expected output: 2 rows -- CONSIGNMENT (approximately 2M) and RISK_PROFILE (8), both with embedding_model = bge-small-en-v1.5 and dimensions = 384.',
    'Simple aggregate scan on entity_embedding. Performance depends on row count after embedding ETL completes.',
    'SIMPLE',
    'SEARCH', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);
