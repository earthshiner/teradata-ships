INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEARCH-001', 1,
    'AIVECTOR used for embedding_vector column instead of VECTOR FLOAT32(n)',
    'embedding_vector is stored as VARBYTE(1536) (384 floats x 4 bytes). mldb.ONNXEmbeddings only supports OutputFormat BLOB, VARBYTE, FLOAT32, or VARCHAR -- it cannot output AIVECTOR directly. VARBYTE(1536) was chosen because TD_VectorDistance accepts VARBYTE columns natively for cosine similarity, and the output column is named sentence_embedding (matching ModelOutputTensor parameter).',
    'Design standard v1.5 references VECTOR FLOAT32(n) or AIVECTOR for native vector storage. {{mldb_V}}.{{ONNXEmbeddings_T}} OutputFormat only accepts BLOB(n), VARBYTE(n), FLOAT32(n), or VARCHAR(n). No user-defined CAST exists from VARBYTE to AIVECTOR on this instance.',
    'Columnar storage pattern using FLOAT columns emb_0 through emb_383. This is supported on older Teradata versions and works with {{TD_VectorDistance_T}} range notation.',
    'VARBYTE(1536) is the most compact single-column storage option from ONNXEmbeddings. {{TD_VectorDistance_T}} accepts VARBYTE columns natively -- confirmed by test scoring two risk profile feature_text strings (HS24 HIGH AIR_MAIL LOW vs HS24 HIGH SEA_CONTAINER LOW, cosine distance 0.0123). Columnar FLOAT32(384) would work but requires 384 extra float columns.',
    'embedding_vector is VARBYTE(1536) not AIVECTOR. TD_VectorDistance queries use TargetFeatureColumns(embedding_vector) with no range notation required -- VARBYTE is accepted natively. If AIVECTOR becomes insertable in a future BYOM version, migration is a column type change only.',
    'ACCEPTED', 'SCHEMA', 'SEARCH', '1.0.0',
    '{{CargoIntelligence_Search_T}}.{{entity_embedding_T}}',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO CargoIntelligence_Memory.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEARCH-002', 1,
    'feature_text stored in {{entity_embedding_T}} despite no-content-duplication principle',
    'The Search Module Design Standard requires storing IDs only and no content duplication. feature_text is stored in {{entity_embedding_T}} as an accepted exception. For CONSIGNMENT rows it is derived and constructed at embedding time from four {{source_T}} columns across three Domain tables and does not exist as a stored column anywhere in the Domain layer. For RISK_PROFILE rows it duplicates RiskProfile_R.feature_text but is also essential embedding metadata documenting exactly what text produced each vector.',
    'Without storing feature_text, auditing what text was embedded requires reconstructing the construction expression from {{source_T}} columns. For CONSIGNMENT rows this is particularly important as value_per_kg bands may shift over time.',
    'Omit feature_text from {{entity_embedding_T}} and reconstruct at query time by joining back to Domain and re-applying the band CASE expression.',
    'feature_text is short (under 100 chars), is metadata about the embedding process itself, and is essential for debugging similarity score anomalies. The storage overhead is trivial relative to the 384-float vector.',
    'If the feature_text construction logic changes (e.g. new vpk_band thresholds), historical embeddings in {{entity_embedding_T}} may have feature_text values that no longer match the current construction rules. This is intentional -- it accurately records what was embedded.',
    'ACCEPTED', 'SCHEMA', 'SEARCH', '1.0.0',
    'CargoIntelligence_Search.entity_embedding',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEARCH-003', 1,
    'similarity_score_max computed in D8 Prediction, not stored in Search',
    'The maximum cosine similarity score between a consignment embedding and the 8 risk profile embeddings (similarity_score_max) is computed during the Prediction module D8 feature store load, not pre-computed and stored in entity_embedding. Search stores vectors; Prediction computes the derived score.',
    'The data lineage declaration includes CI_PRED_SIMILARITY_FEED (entity_embedding to consignment_features), explicitly modelling the similarity scoring as a Prediction module concern. Storing similarity_score_max in Search would duplicate the result in two modules.',
    'Pre-compute similarity_score_max via TD_VectorDistance and store as an additional column in entity_embedding, updated after each embedding refresh.',
    'Keeping score computation in Prediction maintains clean module boundaries. The score is a derived feature (an input to the composite risk model), not a search result. It belongs in the feature store.',
    'The D8 feature store load will include a TD_VectorDistance step over 2M consignment vectors against 8 profile vectors. This is a significant compute step and may be slow on small ClearScape instance.',
    'ACCEPTED', 'ARCHITECTURE', 'SEARCH', '1.0.0',
    'CargoIntelligence_Search.entity_embedding, CargoIntelligence_Prediction.consignment_features',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEARCH-004', 1,
    'mldb.ONNXEmbeddings output vector column name confirmed by diagnostic test before INSERT',
    'The exact output column name from mldb.ONNXEmbeddings is not documented in the design standard and must be confirmed empirically. The 03-etl-load.sql file includes a Step 2 DIAGNOSTIC SELECT that the deployer runs manually against the 8 risk profile rows to inspect function output before executing the production INSERT statements. The INSERT statements use a {vector_output_col} placeholder that the deployer substitutes.',
    'mldb.ONNXEmbeddings is a table-valued function with a runtime-determined output schema. The vector output column name may vary depending on the installed version.',
    'Query the function contract table (mldb.ONNXEmbeddings_contract) to retrieve the declared output schema programmatically.',
    'A hands-on diagnostic test against the actual 8-row risk profile input is more reliable than reading a contract table definition. It also validates the full embedding pipeline before committing to the 2M row consignment batch.',
    'The deployer must manually run Step 2, confirm the output column name, substitute it for {vector_output_col} in Steps 3 and 4, then execute the production inserts. Steps 3 and 4 are NOT directly executable without this substitution.',
    'ACCEPTED', 'OPERATIONAL', 'SEARCH', '1.0.0',
    'CargoIntelligence_Search.entity_embedding',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEARCH-005', 1,
    'bge-small-en-v1.5 selected for embedding structured feature text strings',
    'The embedding model bge-small-en-v1.5 (384 dimensions) is used to embed structured feature text strings of the form HS24 HIGH AIR_MAIL LOW. This is a structured categorical encoding, not natural language. The model was selected because it is already loaded in demo_user.embeddings_models on the ClearScape instance.',
    'bge-small-en-v1.5 is optimised for semantic sentence similarity on natural language text. CargoIntelligence feature text is structured categorical data. The model may assign different similarity scores to structured strings than a model trained specifically on structured data.',
    'Use a larger model (bge-base-en-v1.5, 768 dims). Use a domain-specific model. Use structured similarity scoring without embeddings.',
    'bge-small-en-v1.5 is the only model currently loaded. The structured feature text format is consistent between consignments and profiles, so the model will produce consistent similarity signals within this product even if not ideally suited to structured data.',
    'Similarity scores may not be perfectly calibrated across all feature text combinations. If scores are not discriminating enough, the model can be replaced without changing the schema -- only the embedding_model value and a re-embedding ETL run are required.',
    'ACCEPTED', 'SCHEMA', 'SEARCH', '1.0.0',
    '{{CargoIntelligence_Search_T}}.{{entity_embedding_T}}',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

