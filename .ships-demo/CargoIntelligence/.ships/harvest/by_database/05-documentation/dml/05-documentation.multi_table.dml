INSERT INTO CargoIntelligence_Memory.Change_Log (
    change_id, version_number, change_title, change_description,
    change_type, change_category, source_module, affects_table,
    migration_steps, rollback_steps, related_decision_id,
    deployed_date, deployed_by, deployment_status, created_timestamp
) VALUES (
    'CL-SEARCH-001',
    '1.0.0',
    'Search Module initial release',
    'Initial deployment of CargoIntelligence Search module. Creates {{CargoIntelligence_Search_T}} database with {{entity_embedding_T}} table (embedding_vector VARBYTE(1536)) and v_consignment_searchable view. ETL populates embeddings for 8 RiskProfile_R archetypes and approximately 2M {{Consignment_H_T}} current records using {{mldb_V}}.{{ONNXEmbeddings_T}} with bge-{{small_T}}-en-v1.5 (384 dimensions). Provides vector foundation for {{TD_VectorDistance_T}} similarity scoring in D8 Prediction module. Registers entity_metadata and column_metadata in Semantic module.',
    'INITIAL_RELEASE',
    'NON_BREAKING',
    'SEARCH',
    'ALL',
    'Run 00 through 05 in order. In 03-etl-load.sql, run Step 2 diagnostic first to confirm {{ONNXEmbeddings_T}} output column name, substitute for {vector_output_col}, then run Steps 3 and 4.',
    'DROP DATABASE CargoIntelligence_Search.',
    'DD-SEARCH-004',
    CURRENT_DATE,
    'CargoIntelligence Data Product Team',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6)
);

