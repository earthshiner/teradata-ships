    temporal_pattern, current_flag_column, deleted_flag_column,
    industry_standard, is_active, created_at, updated_at
) VALUES (
    'CountryRisk',
    'Country risk reference with origin_risk_tier classification (HIGH or STANDARD). 199 countries. 5 HIGH-risk countries: China, China HK SAR, Singapore, UAE, Viet Nam. Joins to Consignment via partner_code (UN Comtrade country code).',
    'Domain',
    'CargoIntelligence_Domain',
    'CountryRisk_R',
