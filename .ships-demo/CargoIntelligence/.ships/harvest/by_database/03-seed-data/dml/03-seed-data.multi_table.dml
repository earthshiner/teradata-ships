    relationship_type, cardinality, relationship_meaning,
    is_mandatory, is_active, created_at, updated_at
) VALUES (
    'Consignment_To_Party',
    'Each consignment is sent by one party. Links Consignment_H to the sender Party_H via party_id.',
    'CargoIntelligence_Domain', 'Consignment_H', 'party_id',
    'CargoIntelligence_Domain', 'Party_H', 'party_id',
    'FOREIGN_KEY', 'M:1',
    'A sender party can ship many consignments; each consignment has one sender',
    1, 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

