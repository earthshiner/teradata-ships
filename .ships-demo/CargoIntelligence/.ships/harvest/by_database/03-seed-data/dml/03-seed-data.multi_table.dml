    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.data_product_map (
    module_name, module_description, module_purpose,
    database_name, naming_pattern, table_prefix,
    primary_tables, primary_views,
    module_version, deployment_status, deployed_dts,
    is_active, created_at, updated_at
) VALUES (
    'Observability',
    'Data quality monitoring, agent interaction events, and outcome tracking. Monitors Domain entity load quality, tracks similarity search performance, and captures analyst feedback on risk scoring outcomes to enable closed-loop improvement.',
    'Monitor data product health and enable closed-loop learning',
    'CargoIntelligence_Observability',
