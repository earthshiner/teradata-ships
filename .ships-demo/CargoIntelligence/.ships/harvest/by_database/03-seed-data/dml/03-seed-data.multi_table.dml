    temporal_pattern, current_flag_column, deleted_flag_column,
    industry_standard, is_active, created_at, updated_at
) VALUES (
    'Consignment',
    'Import declaration for a cargo consignment entering Australia. 2M records 2019-2023. Covers HS chapter, declared trade value, net weight, origin country, transport mode, and sender identity. Primary unit of analysis for tobacco smuggling detection.',
    'Domain',
    'CargoIntelligence_Domain',
    'Consignment_H',
    'Consignment_Current',
    'consignment_id',
    'consignment_key',
    'BI_TEMPORAL',
    'is_current',
    'is_deleted',
    'CUSTOM',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

