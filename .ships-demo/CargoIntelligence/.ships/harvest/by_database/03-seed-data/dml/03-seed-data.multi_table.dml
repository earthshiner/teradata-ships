INSERT INTO {{CargoIntelligence_Semantic_T}}.data_product_map (
    module_name, module_description, module_purpose,
    database_name, naming_pattern, table_prefix,
    primary_tables, primary_views,
    module_version, deployment_status, deployed_dts,
    is_active, created_at, updated_at
) VALUES (
    'Domain',
    'Core business entities for cargo consignment risk detection. Five entities: Consignment_H, Party_H, HsCode_R, CountryRisk_R, RiskProfile_R. Bi-temporal history on transactional entities, reference tables for classifications and archetypes.',
    'Source of truth for all cargo consignment business entities',
    'CargoIntelligence_Domain',
    'SEPARATE_DB',
    NULL,
    'Consignment_H, Party_H, HsCode_R, CountryRisk_R, RiskProfile_R',
    'Consignment_Current, Party_Current',
    '1.0.0',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6),
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.data_product_map (
    module_name, module_description, module_purpose,
    database_name, naming_pattern, table_prefix,
    primary_tables, primary_views,
    module_version, deployment_status, deployed_dts,
    is_active, created_at, updated_at
) VALUES (
    'Semantic',
    'Knowledge and meaning layer for CargoIntelligence. Machine-readable metadata: module discovery via data_product_map, entity catalog via entity_metadata, column definitions via column_metadata, join patterns via table_relationship, and naming conventions via naming_standard.',
    'Enable autonomous agent discovery and correct SQL generation',
    'CargoIntelligence_Semantic',
    'SEPARATE_DB',
    NULL,
    'data_product_map, entity_metadata, table_relationship',
    'v_entity_catalog, v_relationship_paths',
    '1.0.0',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6),
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.data_product_map (
    module_name, module_description, module_purpose,
    database_name, naming_pattern, table_prefix,
    primary_tables, primary_views,
    module_version, deployment_status, deployed_dts,
    is_active, created_at, updated_at
) VALUES (
    'Memory',
    'Agent state, learning, and documentation sub-module. Runtime memory tables for session continuity and cross-analyst learning. Documentation sub-module hosts design decisions, business glossary, query cookbook, and change history for all modules.',
