-- -----------------------------------------------------------------------------
-- NAMING_STANDARD -- 10 rows
-- -----------------------------------------------------------------------------

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_H',
    'History table with bi-temporal tracking. Contains full version history with valid_from, valid_to, is_current, and is_deleted columns.',
    'Use for all entities requiring full change history. Filter WHERE is_current = 1 AND is_deleted = 0 for current records.',
    'TABLE',
    'Consignment_H, Party_H',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_R',
    'Reference table. Static or slowly-changing lookup data. No temporal history columns. Filter WHERE is_active = 1 for active records.',
    'Use for classification lookups, code lists, and curated archetypes. No is_current column - use is_active instead.',
    'TABLE',
    'HsCode_R, CountryRisk_R, RiskProfile_R',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_Current',
    'View exposing only current records from a history table. Equivalent to WHERE is_current = 1 AND is_deleted = 0 on the base _H table.',
    'Use for standard analytical queries that do not need historical versions. Preferred access pattern for Domain entities in Prediction and Search joins.',
    'VIEW',
    'Consignment_Current, Party_Current',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_id',
    'Surrogate key column. BIGINT GENERATED ALWAYS AS IDENTITY. System-assigned, never exposed to business users. Used as the physical join key between tables.',
    'Always join on _id columns, not _key columns, for performance. Example: JOIN Party_H ON Party_H.party_id = Consignment_H.party_id',
    'COLUMN',
    'consignment_id, party_id, hs_code_id, country_risk_id, risk_profile_id',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_key',
    'Natural business key column. Business-meaningful identifier sourced from the source system. Used for display and lookup by analysts, not for physical joins.',
    'Use _key columns in WHERE clauses when filtering by business value. Use _id columns for table joins.',
    'COLUMN',
    'consignment_key, party_key, profile_code',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'PREFIX', 'is_',
    'Boolean flag column. BYTEINT NOT NULL DEFAULT 0 or 1. Filter with = 1 (true) or = 0 (false). Never use Y/N string comparison.',
    'All boolean columns use BYTEINT and is_ prefix. Filter: WHERE is_current = 1 not WHERE is_current = Y',
    'COLUMN',
    'is_current, is_deleted, is_active, is_tobacco_chapter, is_disguise_category',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_dts',
    'Datetime stamp column. TIMESTAMP(6) WITH TIME ZONE. Always stored in UTC. Use for event timestamps requiring sub-second precision.',
    'Use _dts for event timestamps (interaction_dts, deployed_dts). Use _at for audit timestamps (created_at, updated_at). Use _date for DATE columns.',
    'COLUMN',
    'interaction_dts, session_start_dts, session_end_dts, deployed_dts',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_at',
    'Audit timestamp column. TIMESTAMP(6) WITH TIME ZONE. Records when the row was created or last modified in the data product, not when the business event occurred.',
    'Every table must have created_at and updated_at audit columns using CURRENT_TIMESTAMP(6) defaults.',
    'COLUMN',
    'created_at, updated_at',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'SUFFIX', '_json',
    'JSON document column. Stores complex or flexible structured data. Agents should retrieve the full JSON document and parse it in application code, not filter inside Teradata SQL.',
    'Use for context or metadata with variable structure. Do not use for values needing SQL-level filtering - use VARCHAR instead.',
    'COLUMN',
    'session_context_json, pattern_definition_json, allowed_values_json',
    1, CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.naming_standard (
    standard_type, standard_value, meaning, usage_guidance, applies_to, examples, is_active, created_at
) VALUES (
    'PATTERN', '{ProductName}_{ModuleName}',
    'Database naming convention for Approach 1 (separate databases per module). Each module has its own Teradata database named as ProductName underscore ModuleName.',
    'Agent bootstrap: construct Semantic database name as {ProductName}_Semantic, then query data_product_map to discover all other module databases.',
    'ALL',
    'CargoIntelligence_Domain, CargoIntelligence_Semantic, CargoIntelligence_Memory, CargoIntelligence_Search, CargoIntelligence_Prediction, CargoIntelligence_Observability',
    1, CURRENT_TIMESTAMP(6)
);
