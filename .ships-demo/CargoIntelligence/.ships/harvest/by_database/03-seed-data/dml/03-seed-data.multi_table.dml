);

INSERT INTO {{CargoIntelligence_Semantic_T}}.entity_metadata (
    entity_name, entity_description, module_name, database_name,
    table_name, view_name, surrogate_key_column, natural_key_column,
    temporal_pattern, current_flag_column, deleted_flag_column,
    industry_standard, is_active, created_at, updated_at
) VALUES (
    'RiskProfile',
    'Curated tobacco smuggling archetype. 8 seeded profiles: 1 direct tobacco (HS 24), 6 tobacco-in-disguise (HS 20,22,25,39,63,94), 1 baseline legitimate. Each profile encodes hs_chapter, origin_risk_tier, transport_mode, and value_density_range as a feature_text for embedding. Anchor points for Search module similarity scoring.',
    'Domain',
    'CargoIntelligence_Domain',
    'RiskProfile_R',
    NULL,
    'risk_profile_id',
    'profile_code',
    'NONE',
    'is_active',
    NULL,
    'CUSTOM',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

