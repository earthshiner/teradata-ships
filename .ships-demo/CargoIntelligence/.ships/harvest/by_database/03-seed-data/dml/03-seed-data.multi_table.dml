INSERT INTO {{CargoIntelligence_Semantic_T}}.data_product_map (
    module_name, module_description, module_purpose,
    database_name, naming_pattern, table_prefix,
    primary_tables, primary_views,
    module_version, deployment_status, deployed_dts,
    is_active, created_at, updated_at
) VALUES (
    'Search',
    'Structured vector similarity search for tobacco smuggling detection. Encodes consignments as feature strings, embeds via ONNX in-database, scores against RiskProfile archetypes using TD_VectorDistance cosine. Produces similarity_score_max for the Prediction feature store.',
    'Structured embedding and similarity scoring for risk detection',
    'CargoIntelligence_Search',
    'SEPARATE_DB',
    NULL,
    'entity_embedding',
    NULL,
    '1.0.0',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6),
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Semantic_T}}.data_product_map (
    module_name, module_description, module_purpose,
    database_name, naming_pattern, table_prefix,
    primary_tables, primary_views,
    module_version, deployment_status, deployed_dts,
    is_active, created_at, updated_at
) VALUES (
    'Prediction',
    'Feature store and composite risk scoring. Pre-computed features: value_density_score, origin_risk_score, hs_adjacency_risk, trade_asymmetry_score, consignee_network_flag, similarity_score_max (from Search), composite_risk_score. Terminal module - no downstream dependents.',
    'Feature store and composite risk score for tobacco smuggling detection',
    'CargoIntelligence_Prediction',
    'SEPARATE_DB',
    NULL,
    'consignment_features, model_prediction',
    NULL,
    '1.0.0',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6),
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

