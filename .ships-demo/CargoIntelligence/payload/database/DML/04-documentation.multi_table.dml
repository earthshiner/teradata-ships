INSERT INTO {{CargoIntelligence_Memory_T}}.Change_Log (
    change_id, version_number, change_title, change_description,
    change_type, change_category, source_module, affects_table,
    migration_steps, rollback_steps, related_decision_id,
    deployed_date, deployed_by, deployment_status, created_timestamp
) VALUES (
    'CL-SEMANTIC-001',
    '1.0.0',
    'Semantic Module initial release',
    'Initial deployment of CargoIntelligence Semantic module. Creates CargoIntelligence_Semantic database with 5 metadata tables and 3 views. Seeds data_product_map with 6 module rows, entity_metadata with 5 Domain entity rows, table_relationship with 8 relationship rows (5 intra-Domain, 3 cross-module), naming_standard with 10 convention rows. column_metadata seeded with 0 rows - populated in D5 Domain module.',
    'INITIAL_RELEASE',
    'NON_BREAKING',
    'SEMANTIC',
    'ALL',
    'Run 00-setup.sql, 01-tables.sql, 02-views.sql, 03-seed-data.sql, 04-documentation.sql in sequence.',
    'DROP DATABASE CargoIntelligence_Semantic',
    'DD-SEMANTIC-003',
    CURRENT_DATE,
    'CargoIntelligence Data Product Team',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6)
);

