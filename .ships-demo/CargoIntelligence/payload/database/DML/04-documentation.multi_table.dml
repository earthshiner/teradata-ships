INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Entity (Semantic)',
    'ENTITY',
    'In the Semantic module, an entity is a table - a physical database object that stores instances of a business concept. Entity metadata describes what tables exist, where they are located, what their key columns are, and what temporal pattern they use. Agents use entity_metadata as the primary table catalog.',
    'entity_metadata is the first table agents should query after data_product_map. It answers: what tables exist, which database, how to get current records, and what the primary key is.',
    'Table, Object',
    'Relationship, Attribute, data_product_map',
    'CargoIntelligence_Semantic.entity_metadata',
    NULL,
    'SEMANTIC', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Relationship',
    'BUSINESS_RULE',
    'A documented join pattern between two tables, registered in table_relationship. Defines source table, source column, target table, target column, cardinality, and relationship type. Agents use table_relationship via v_relationship_paths to discover how to write correct JOIN clauses without human guidance.',
    'table_relationship uses from_table/to_table/from_column/to_column naming (MortgagePlatform alignment). The v_relationship_paths view provides multi-hop traversal up to 5 hops. Cross-module relationships are registered here even before the target tables are deployed.',
    'Join, Foreign Key, Association',
    'Entity (Semantic), v_relationship_paths',
    'CargoIntelligence_Semantic.table_relationship',
    NULL,
    'SEMANTIC', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Feature Text',
    'ATTRIBUTE',
    'A semantically meaningful string encoding of a consignment or risk profile constructed from structured attributes (hs_chapter, origin_risk_tier, transport_code, value_per_kg range, is_disguise_category). Used as the input to the ONNX embedding model in the Search module. Makes similarity structural rather than purely textual, reducing false positives.',
    'Feature text encoding is the key design choice that makes CargoIntelligence similarity search structural. By encoding categorical and numerical attributes as a canonical string, the embedding captures business meaning rather than text surface form. Example format: HS24|HIGH|AIR_MAIL|HIGH_VALUE|TOBACCO',
    'Embedding Input, Feature String',
    'Risk Profile, Similarity Score, entity_embedding',
    'CargoIntelligence_Search.entity_embedding',
    'feature_text',
    'SEMANTIC', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

-- -----------------------------------------------------------------------------
-- QUERY_COOKBOOK -- 2 rows
-- -----------------------------------------------------------------------------

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEMANTIC-003',
    'Multi-hop path discovery using v_relationship_paths',
    'Queries v_relationship_paths to find the shortest join path between any two tables, up to 5 hops. The view uses a recursive CTE over table_relationship. Returns path_tables (the traversal sequence) and path_joins (ready-to-use JOIN conditions). Filter by hop_count to find the shortest path.',
    'Agent join path discovery across multiple tables',
    'SEMANTIC',
    'SELECT vr.hop_count, vr.path_tables, vr.path_joins FROM CargoIntelligence_Semantic.v_relationship_paths vr WHERE vr.source_table = [table_a] AND vr.target_table = [table_b] ORDER BY vr.hop_count',
    '[table_a] = starting table name e.g. Consignment_H. [table_b] = target table name e.g. consignment_features. Returns all paths ordered by hop count shortest first.',
    'Recursive CTE over a small metadata table - no performance concerns at expected relationship counts.',
    'SIMPLE',
    'SEMANTIC', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEMANTIC-004',
    'Discover all deployed and active entities',
    'Returns all active entity registrations across all modules. Use at session start to understand what tables exist, which module they belong to, and what their primary key columns are before generating any domain SQL.',
    'Agent initialization, SQL generation',
    'SEMANTIC',
    'SELECT vc.entity_name, vc.module_name, vc.database_name, vc.table_name, vc.view_name, vc.surrogate_key_column, vc.natural_key_column, vc.temporal_pattern FROM CargoIntelligence_Semantic.v_entity_catalog vc ORDER BY vc.module_name, vc.entity_name',
    'No parameters. Returns all active entities. Filter by module_name for module-specific discovery e.g. WHERE vc.module_name = Domain',
    'Lightweight scan on a small metadata table - no performance concerns.',
    'SIMPLE',
    'SEMANTIC', '1.0.0', 1,
    CURRENT_DATE, DATE '9999-12-31', CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);
