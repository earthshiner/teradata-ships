INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEMANTIC-001', 1,
    'entity_metadata populated for Domain entities only at initial deployment',
    'At Semantic v1.0.0, entity_metadata contains 5 rows covering the 5 Domain entities. Entities from other modules (entity_embedding in Search, consignment_features in Prediction, etc.) will be added as those modules are deployed.',
    'entity_metadata is the agent entity catalog for the entire data product. At initial deployment only the Domain module entities are known, so only Domain entities are registered.',
    'Register placeholder rows for all anticipated entities across all modules upfront.',
    'Register entities only when their tables are physically deployed. Placeholder rows for non-existent tables would mislead agents into querying tables that do not yet exist.',
    'Semantic module must be updated incrementally as each new module deploys. The 04-documentation.sql file for each future module must include entity_metadata INSERTs for that modules entities.',
    'ACCEPTED', 'SCHEMA', 'SEMANTIC', '1.0.0',
    'CargoIntelligence_Semantic.entity_metadata',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEMANTIC-002', 1,
    'column_metadata populated in Domain module brief, not Semantic',
    'The column_metadata table is created here (Semantic) but populated with 0 rows at Semantic deployment. All column_metadata INSERTs for Domain tables are included in the Domain module D5 documentation script.',
    'Column-level metadata requires knowledge of exact column names and types, which are defined in the Domain module DDL. Writing column_metadata INSERTs before the Domain tables are designed would require duplicating column specifications.',
    'Populate column_metadata for all Domain columns as part of the Semantic module brief.',
    'Domain module brief is the authoritative source for column definitions. Generating column_metadata alongside Domain DDL avoids drift and ensures consistency.',
    'Agents bootstrapping from Semantic before Domain is deployed will find entity_metadata rows but no column_metadata rows for Domain tables. This is expected and documented.',
    'ACCEPTED', 'SCHEMA', 'SEMANTIC', '1.0.0',
    'CargoIntelligence_Semantic.column_metadata',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEMANTIC-003', 1,
    'table_relationship uses from_table/to_table column naming (MortgagePlatform alignment)',
    'The table_relationship table uses from_database, from_table, from_column, to_database, to_table, to_column column names, aligned to the tested MortgagePlatform Semantic module implementation. The AI-Native Data Product design standard DDL uses source_table/target_table but the MortgagePlatform implementation uses from_/to_ and is confirmed working on ClearScape including the recursive CTE v_relationship_paths view.',
    'Two naming conventions exist in the framework: the design standard DDL (source_*/target_*) and the MortgagePlatform tested implementation (from_*/to_*). The MortgagePlatform v_relationship_paths recursive CTE view uses from_/to_ and is the proven production pattern.',
    'Follow the design standard DDL column names (source_table/target_table) and rewrite the v_relationship_paths CTE to match.',
    'Aligning to the tested MortgagePlatform implementation reduces risk. The recursive CTE v_relationship_paths is proven working on ClearScape when using from_/to_ column names. Rewriting the CTE with different column names introduces untested risk.',
    'table_relationship column names differ from the design standard DDL. All queries against table_relationship and v_relationship_paths must use from_table/to_table not source_table/target_table. The design standard DDL should be updated in a future version.',
    'ACCEPTED', 'NAMING', 'SEMANTIC', '1.0.0',
    'CargoIntelligence_Semantic.table_relationship, CargoIntelligence_Semantic.v_relationship_paths',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SEMANTIC-004', 1,
    'Cross-module joins registered in table_relationship at Semantic deployment',
    'table_relationship includes 3 cross-module rows: Consignment_H to entity_embedding (Search), Consignment_H to consignment_features (Prediction), and entity_embedding to consignment_features. These are registered as ASSOCIATIVE relationships at Semantic deployment even though Search and Prediction tables do not yet exist.',
    'The design standard requires all expected agent traversal paths to be registered. The Search-to-Prediction integration via similarity_score_max is the core architectural narrative and must be discoverable from day one.',
    'Register cross-module relationships only once the target module tables are physically deployed.',
    'Cross-module join paths are architectural decisions, not implementation details. Registering them at Semantic deployment ensures the intended data flow is documented before the modules are built.',
    'v_relationship_paths will include rows referencing tables in CargoIntelligence_Search and CargoIntelligence_Prediction that do not yet exist. Agents must check entity_metadata is_active = 1 to confirm a table is deployed before querying it.',
    'ACCEPTED', 'INTEGRATION', 'SEMANTIC', '1.0.0',
    'CargoIntelligence_Semantic.table_relationship',
    'CargoIntelligence Data Product Team', CURRENT_DATE,
    CURRENT_DATE, DATE '9999-12-31', 1, CURRENT_TIMESTAMP(6), CURRENT_TIMESTAMP(6)
);

