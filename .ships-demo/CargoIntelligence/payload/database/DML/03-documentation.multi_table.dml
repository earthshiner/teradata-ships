INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Consignment',
    'ENTITY',
    'A single import declaration of goods entering Australia, modelled on the ABF mail cargo declaration structure. Each consignment captures declared HS chapter, trade value, net weight, origin country, transport mode, and sender identity. The primary unit of analysis in CargoIntelligence.',
    'Sourced from STG_Cargo_Consignments (2M records, 2019-2023). Ground truth risk labels (segment, is_under_declared) are present in staging but excluded from the Domain layer to prevent leakage into operational scoring.',
    'Declaration, Shipment',
    'Risk Profile, HS Chapter, Origin Risk Tier',
    'CargoIntelligence_Domain.Consignment_H',
    NULL,
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Risk Profile',
    'ENTITY',
    'A curated archetype representing a known tobacco smuggling pattern. Each risk profile encodes a combination of HS chapter affinity, origin risk tier, transport mode, and value density range as a structured feature string. Risk profiles are the reference anchor points that Search module similarity scoring scores consignments against using TD_VectorDistance cosine distance.',
    'Eight profiles are seeded: 1 direct tobacco (declared as HS 24), 6 tobacco-in-disguise patterns (one per disguise HS chapter: 20, 22, 25, 39, 63, 94), and 1 baseline legitimate profile. Profiles are curated domain knowledge, not derived from staging data.',
    'Smuggling Archetype, Risk Archetype',
    'Consignment, Similarity Score, HS Chapter',
    'CargoIntelligence_Domain.RiskProfile_R',
    NULL,
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'HS Chapter',
    'REFERENCE_CODE',
    'A 2-digit Harmonized System chapter code classifying imported goods by commodity type. CargoIntelligence covers 17 HS chapters. Chapter 24 (Tobacco) is the primary detection target. Chapters 20, 22, 25, 39, 63, 94 are designated disguise categories - goods commonly used to mis-declare tobacco shipments.',
    'The 7 chapters in UN Comtrade TradeStats (20, 22, 24, 25, 39, 63, 94) provide benchmark value_per_kg statistics used in trade asymmetry scoring. The remaining 10 chapters in consignment data provide context for normal import patterns.',
    'HS Code, Commodity Chapter',
    'Consignment, Risk Profile, Origin Risk Tier',
    'CargoIntelligence_Domain.HsCode_R',
    NULL,
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Origin Risk Tier',
    'CLASSIFICATION',
    'A classification of an origin country by its historical association with tobacco smuggling into Australia. Two tiers: HIGH (5 countries: China, China HK SAR, Singapore, UAE, Viet Nam) and STANDARD (all others). Derived from UN Comtrade TradeStats analysis and ABF intelligence.',
    'In CargoIntelligence staging data 62% of consignments originate from HIGH risk countries. The 5 HIGH-risk countries account for the majority of detected tobacco smuggling attempts via disguise categories in the 2019-2023 period.',
    'Country Risk, Origin Classification',
    'Consignment, CountryRisk, Risk Profile',
    'CargoIntelligence_Domain.CountryRisk_R',
    'origin_risk_tier',
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Business_Glossary (
    term, term_category, definition, business_context,
    synonyms, related_terms, related_table, related_column,
    source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'Similarity Score',
    'METRIC',
    'The cosine distance between a consignment embedding vector and its most similar risk profile embedding vector, computed via TD_VectorDistance in-database. Stored as similarity_score_max in the Prediction feature store. A score close to 1.0 indicates the consignment structurally resembles a known smuggling archetype.',
    'similarity_score_max is computed in CargoIntelligence_Search and written to CargoIntelligence_Prediction.consignment_features. It is one of 7 features contributing to composite_risk_score. The Search-to-Prediction integration via this metric is the core architectural differentiator of this reference implementation.',
    'Vector Similarity, Cosine Similarity',
    'Risk Profile, Composite Risk Score, Consignment',
    'CargoIntelligence_Search.entity_embedding',
    'similarity_score_max',
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

-- -----------------------------------------------------------------------------
-- QUERY_COOKBOOK — 3 rows
-- -----------------------------------------------------------------------------

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-MEMORY-001',
    'Find all agent interactions involving a specific entity',
    'Retrieves all agent interactions that queried or acted on a specified table, ordered by most recent first. Uses LIKE filter on the comma-separated referenced_tables VARCHAR column. Useful for auditing which agents have accessed a given entity and what SQL they executed.',
    'Audit and session review',
    'MEMORY',
    'SELECT vis.session_key, vis.agent_key, vis.interaction_seq, vis.interaction_type, vis.user_input, vis.sql_executed, vis.query_result_count, vis.outcome_status, vis.interaction_dts FROM CargoIntelligence_Memory.v_interactions_summary vis WHERE vis.referenced_tables LIKE :table_pattern AND vis.interaction_type = :interaction_type ORDER BY vis.interaction_dts DESC;',
    ':table_pattern = table name fragment wrapped in % wildcards e.g. %Consignment_H%. :interaction_type = QUERY, DECISION, ACTION, or EXPLANATION. Omit the interaction_type filter to return all types.',
    'Lightweight LIKE scan on VARCHAR(1000). No performance concerns at expected interaction volumes.',
    'SIMPLE',
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEMANTIC-001',
    'Agent bootstrap: discover modules then entities',
    'Standard agent initialization sequence for CargoIntelligence. Step 1 queries data_product_map to discover which modules are deployed and their database locations. Step 2 queries entity_metadata to discover what tables exist in a given module. Run these two queries in sequence at session start before generating any domain SQL.',
    'Agent initialization, onboarding',
    'SEMANTIC',
    '-- Step 1: Discover deployed modules
SELECT module_name, database_name, primary_tables, module_description
FROM CargoIntelligence_Semantic.data_product_map
WHERE is_active = 1;

-- Step 2: Discover entities in a module
SELECT entity_name, table_name, view_name, natural_key_column, entity_description
FROM CargoIntelligence_Semantic.entity_metadata
WHERE module_name = :module_name
  AND is_active = 1;',
    ':module_name = the module to explore e.g. Domain, Search, or Prediction.',
    'Both queries operate on small metadata tables. No performance concerns.',
    'SIMPLE',
    'MEMORY',
    '1.0.0',
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Query_Cookbook (
    recipe_id, recipe_title, recipe_description, use_case,
    target_module, sql_template, parameter_descriptions, performance_notes,
    complexity, source_module, module_version, is_active,
    valid_from, valid_to, created_timestamp, updated_timestamp
) VALUES (
    'QC-SEMANTIC-002',
    'Generate entity-relationship diagram from table_relationship',
    'Queries the Semantic table_relationship table to produce a complete entity-relationship listing for CargoIntelligence. Output can be formatted as Mermaid erDiagram syntax or as a plain relationship listing. Use to verify the current data model without relying on a static diagram that may have drifted.',
    'Data model documentation, onboarding, design review',
    'SEMANTIC',
