INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SCOPE-001',
    1,
    'Separate databases per module (Approach 1)',
    'CargoIntelligence uses Approach 1: one database per module (CargoIntelligence_Memory, CargoIntelligence_Semantic, CargoIntelligence_Domain, CargoIntelligence_Observability, CargoIntelligence_Search, CargoIntelligence_Prediction). This is the recommended approach in the AI-Native Data Product design standard.',
    'The design standard offers two approaches: Approach 1 (separate databases per module) or Approach 2 (single database with module-prefixed tables). As a reference implementation this product must demonstrate best practice architecture.',
    'Approach 2: single CargoIntelligence database with module-prefixed tables (D_, S_, M_, etc.). Simpler to manage on a small ClearScape instance with fewer cross-database grant requirements.',
    'A reference implementation for the Department of Home Affairs SVoE modernisation narrative must demonstrate the recommended enterprise pattern. Separate databases give independent access control per module, support incremental deployment, and align with the six-module architecture concept.',
    'Six databases to manage. Cross-database views require GRANT SELECT WITH GRANT OPTION before creation. Deployment must follow phase order: Memory and Semantic first, then Domain and Observability, then Search and Prediction.',
    'ACCEPTED',
    'ARCHITECTURE',
    'MEMORY',
    '1.0.0',
    'ALL',
    'CargoIntelligence Data Product Team',
    CURRENT_DATE,
    CURRENT_DATE,
    DATE '9999-12-31',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-SCOPE-002',
    1,
    'All six modules deployed - no deferrals',
    'All six AI-Native Data Product modules are in scope for CargoIntelligence and will be deployed: Memory, Semantic, Domain, Observability, Search, and Prediction. No modules are deferred or excluded.',
    'Some data products deploy a subset of modules to reduce build complexity. CargoIntelligence is a reference implementation for the Department of Home Affairs SVoE modernisation conversation and must demonstrate the complete architecture.',
    'Deploy Domain, Semantic, and Search only as a minimum viable product. Defer Prediction and Observability to a later phase to reduce initial build scope.',
    'Full module deployment is required to demonstrate the Search-to-Prediction integration via similarity_score_max feeding composite_risk_score. This cross-module dependency is the key architectural differentiator for the SVoE modernisation narrative.',
    'Higher build complexity across six modules. All cross-module GRANT SELECT WITH GRANT OPTION statements must be established in the correct deployment order.',
    'ACCEPTED',
    'ARCHITECTURE',
    'MEMORY',
    '1.0.0',
    'ALL',
    'CargoIntelligence Data Product Team',
    CURRENT_DATE,
    CURRENT_DATE,
    DATE '9999-12-31',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-MEMORY-001',
    1,
    'ORGANIZATION scope default for cargo inspection agent interactions',
    'All agent sessions and interactions in the CargoIntelligence Memory module default to scope_level = ORGANIZATION. Individual analyst preferences use scope_level = USER. No TEAM scope is used in this product.',
    'The design standard supports four scope levels: USER, TEAM, ORGANIZATION, and AGENT. CargoIntelligence is a government border protection product where learned query strategies and discovered risk patterns are operationally valuable across all analysts.',
    'USER scope for all interactions (more private, less knowledge sharing). TEAM scope for analyst teams within the Australian Border Force.',
    'Cross-analyst learning is essential in border protection operations. A risk pattern discovered by one analyst (such as a high-similarity sender cluster) must be visible to all analysts. ORGANIZATION scope maximises knowledge sharing and improves detection capability over time.',
    'All agent_session, agent_interaction, learned_strategy, and discovered_pattern records default scope_level to ORGANIZATION. user_preference records default to USER scope for personal settings.',
    'ACCEPTED',
    'SECURITY',
    'MEMORY',
    '1.0.0',
    'agent_session, agent_interaction, learned_strategy, discovered_pattern',
    'CargoIntelligence Data Product Team',
    CURRENT_DATE,
    CURRENT_DATE,
    DATE '9999-12-31',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-MEMORY-002',
    1,
    'VARCHAR comma-separated for referenced_tables and involved_tables',
    'Table references in agent_interaction.referenced_tables and discovered_pattern.involved_tables use VARCHAR(1000) comma-separated format. Format is: CargoIntelligence_Domain.Consignment_H, CargoIntelligence_Search.entity_embedding. This enables direct LIKE-based SQL filtering without application-layer JSON parsing.',
    'The design standard offers VARCHAR (comma-separated) or JSON for storing lists of table names in memory records. Teradata JSON retrieval requires application-side parsing to extract values for filtering.',
    'JSON array column storing fully-qualified table names as a JSON list, consistent with other JSON columns in the schema.',
    'LIKE queries on VARCHAR work directly in SQL. Agents can filter WHERE referenced_tables LIKE CargoIntelligence_Domain.Consignment_H without application-side processing. Consistent with the design standard recommendation for table reference lists.',
    'Format must be consistently applied: fully qualified database.table_name separated by commas and a space. Parsing multiple tables from one record requires application-layer split on comma if individual table counts are needed.',
    'ACCEPTED',
    'SCHEMA',
    'MEMORY',
    '1.0.0',
    'agent_interaction, discovered_pattern',
    'CargoIntelligence Data Product Team',
    CURRENT_DATE,
    CURRENT_DATE,
    DATE '9999-12-31',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

INSERT INTO {{CargoIntelligence_Memory_T}}.Design_Decision (
    decision_id, decision_version, decision_title, decision_description,
    context, alternatives_considered, rationale, consequences,
    decision_status, decision_category, source_module, module_version,
    affects_table, decided_by, decided_date,
    valid_from, valid_to, is_current, created_timestamp, updated_timestamp
) VALUES (
    'DD-MEMORY-003',
    1,
    'RiskProfile_R added as fifth Domain entity',
    'The original session intent specified four Domain entities (Consignment, Party, HsCode, CountryRisk). RiskProfile was added as a fifth Domain entity (RiskProfile_R, reference table suffix _R) based on source profiling findings and architectural review during design.',
    'Source profiling of CargoIntelligence_Staging found no pre-built risk profile records. Risk profiles must be constructed as curated reference patterns in the Domain layer. The Search module scores consignments against RiskProfile embeddings, requiring both to have stable identities in the Domain.',
    'Define risk profiles purely within the Search module as internal configuration or lookup data, not as a formal Domain entity with its own surrogate key and history.',
    'RiskProfile must be independently queryable and auditable by ABF analysts separate from the search scoring logic. It naturally joins to HsCode_R and CountryRisk_R. The Search module embeds RiskProfile_R records using the same pipeline as Consignment_H, so both require Domain-layer identity for consistent cross-module join patterns.',
    'Domain module has five entities instead of four. Search module embeds both Consignment_H and RiskProfile_R. RiskProfile_R requires 8 seed INSERT records (curated archetypes) during Domain module deployment.',
    'ACCEPTED',
    'ARCHITECTURE',
    'MEMORY',
    '1.0.0',
    'CargoIntelligence_Domain.RiskProfile_R',
    'CargoIntelligence Data Product Team',
    CURRENT_DATE,
    CURRENT_DATE,
    DATE '9999-12-31',
    1,
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

