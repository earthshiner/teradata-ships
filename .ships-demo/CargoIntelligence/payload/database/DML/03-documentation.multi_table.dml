INSERT INTO {{CargoIntelligence_Memory_T}}.Change_Log (
    change_id, version_number, change_title, change_description,
    change_type, change_category, source_module, affects_table,
    migration_steps, rollback_steps, related_decision_id,
    deployed_date, deployed_by, deployment_status, created_timestamp
) VALUES (
    'CL-MEMORY-001',
    '1.0.0',
    'Memory Module initial release',
    'Initial deployment of CargoIntelligence Memory module. Creates CargoIntelligence_Memory database with 5 runtime memory tables (agent_session, agent_interaction, learned_strategy, user_preference, discovered_pattern) and 6 Documentation Sub-Module tables (Module_Registry, Design_Decision, Business_Glossary, Query_Cookbook, Implementation_Note, Change_Log). Includes 8 standard views. Seeds Module_Registry with all 6 product modules, Design_Decision with 5 scope and module decisions, Business_Glossary with 5 CargoIntelligence terms, and Query_Cookbook with 3 recipes including the mandatory QC-SEMANTIC-002 ERD recipe.',
    'INITIAL_RELEASE',
    'NON_BREAKING',
    'MEMORY',
    'ALL',
    'Run 00-setup.sql, then 01-tables.sql, then 02-views.sql, then 03-documentation.sql in sequence.',
    'DROP DATABASE CargoIntelligence_Memory',
    'DD-SCOPE-001',
    CURRENT_DATE,
    'CargoIntelligence Data Product Team',
    'DEPLOYED',
    CURRENT_TIMESTAMP(6)
);

