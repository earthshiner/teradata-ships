) VALUES (
    'MEMORY',
    'CargoIntelligence_Memory',
    'DEPLOYED',
    '1.0.0',
    'Agent state, learning, and documentation sub-module for the CargoIntelligence data product. Hosts runtime memory tables (sessions, interactions, strategies, preferences, patterns) and design memory tables (Module_Registry, Design_Decision, Business_Glossary, Query_Cookbook, Implementation_Note, Change_Log). Enables agent continuity across cargo inspection sessions and captures architectural decisions made during design.',
    'agent_session, agent_interaction, learned_strategy, user_preference, discovered_pattern, Module_Registry, Design_Decision, Business_Glossary, Query_Cookbook, Change_Log',
    'None - Memory is a Phase 1 module, no upstream dependencies',
    'SEMANTIC, DOMAIN, OBSERVABILITY, SEARCH, PREDICTION',
    'Australian Border Force Data Architecture',
    'CargoIntelligence Data Product Team',
    'REAL_TIME',
    CURRENT_DATE,
    1,
    CURRENT_DATE,
    DATE '9999-12-31',
    CURRENT_TIMESTAMP(6),
    CURRENT_TIMESTAMP(6)
);

