CREATE MULTISET TABLE {{CargoIntelligence_Domain_T}}.{{Consignment_Keymap_T}} (
    {{consignment_id_T}}  BIGINT GENERATED ALWAYS AS IDENTITY (START WITH 1 INCREMENT BY 1) NOT NULL,
    consignment_key VARCHAR(30) NOT NULL,
    source_system   VARCHAR(50) DEFAULT 'ABF_CARGO',
    created_dt      TIMESTAMP(6) WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP(6)
)
UNIQUE PRIMARY INDEX (consignment_key);