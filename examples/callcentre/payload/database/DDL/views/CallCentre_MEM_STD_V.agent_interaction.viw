CREATE VIEW {{CallCentre_MEM_STD_V}}.agent_interaction
(
      interaction_id
    , session_id
    , interaction_seq
    , interaction_type
    , interaction_dts
    , user_input
    , agent_response
    , action_taken
    , referenced_tables
    , sql_executed
    , query_result_count
    , execution_time_ms
    , outcome_status
    , user_feedback
    , scope_level
    , scope_identifier
    , created_at
)
AS
LOCKING ROW FOR ACCESS
SELECT
      interaction_id
    , session_id
    , interaction_seq
    , interaction_type
    , interaction_dts
    , user_input
    , agent_response
    , action_taken
    , referenced_tables
    , sql_executed
    , query_result_count
    , execution_time_ms
    , outcome_status
    , user_feedback
    , scope_level
    , scope_identifier
    , created_at
FROM {{CallCentre_MEM_STD_T}}.agent_interaction;
