REPLACE VIEW {{CallCentre_MEM_BUS_V}}.learned_strategies_org
(
    strategy_id
   ,strategy_name
   ,strategy_category
   ,applies_to_scenario
   ,strategy_pattern
   ,times_used
   ,success_rate
   ,discovered_dts
   ,discovered_by_agent
   ,validation_dts
)
AS
SELECT
    strategy_id
   ,strategy_name
   ,strategy_category
   ,applies_to_scenario
   ,strategy_pattern
   ,times_used
   ,success_rate
   ,discovered_dts
   ,discovered_by_agent
   ,validation_dts
FROM {{CallCentre_MEM_STD_V}}.learned_strategy
WHERE is_active = 1
  AND is_validated = 1
  AND scope_level =; 'ORGANIZATION'
