--CallCentre_MEM_BUS_V.learned_strategies_org.applies_to_scenario|VARCHAR(500)
--CallCentre_MEM_BUS_V.learned_strategies_org.strategy_pattern|VARCHAR(4000)
--CallCentre_MEM_BUS_V.learned_strategies_org.times_used|INTEGER
--CallCentre_MEM_BUS_V.learned_strategies_org.success_rate|DECIMAL(5,4)
--CallCentre_MEM_BUS_V.learned_strategies_org.discovered_dts|TIMESTAMP WITH TIME ZONE
--CallCentre_MEM_BUS_V.learned_strategies_org.discovered_by_agent|VARCHAR(100)
