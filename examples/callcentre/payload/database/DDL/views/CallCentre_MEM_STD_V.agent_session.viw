CREATE VIEW {{CallCentre_MEM_STD_V}}.agent_session
(
      session_id
    , session_key
    , agent_key
    , user_key
    , session_start_dts
    , session_end_dts
    , session_status
    , session_goal
    , session_context_json
    , scope_level
    , scope_identifier
    , created_at
)
AS
LOCKING ROW FOR ACCESS
SELECT
      session_id
    , session_key
    , agent_key
    , user_key
    , session_start_dts
    , session_end_dts
    , session_status
    , session_goal
    , session_context_json
    , scope_level
    , scope_identifier
    , created_at
FROM {{CallCentre_MEM_STD_T}}.agent_session;
