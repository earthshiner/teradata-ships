CREATE VIEW {{CallCentre_OBS_STD_V}}.agent_outcome
(
      outcome_id
    , agent_key
    , session_key
    , action_type
    , action_dts
    , tables_accessed
    , outcome_status
    , user_feedback
    , execution_time_ms
    , records_processed
    , created_at
)
AS
LOCKING ROW FOR ACCESS
SELECT
      outcome_id
    , agent_key
    , session_key
    , action_type
    , action_dts
    , tables_accessed
    , outcome_status
    , user_feedback
    , execution_time_ms
    , records_processed
    , created_at
FROM {{CallCentre_OBS_STD_T}}.agent_outcome;
