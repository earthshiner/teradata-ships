--CallCentre_SEM_BUS_V.data_product_orientation.product_name|VARCHAR(256)
--CallCentre_SEM_BUS_V.data_product_orientation.product_version|VARCHAR(32)
--CallCentre_SEM_BUS_V.data_product_orientation.resource_role|VARCHAR(50)
--CallCentre_SEM_BUS_V.data_product_orientation.database_name|VARCHAR(128)
--CallCentre_SEM_BUS_V.data_product_orientation.object_name|VARCHAR(128)
--CallCentre_SEM_BUS_V.data_product_orientation.fully_qualified_object_name|VARCHAR(257)
--CallCentre_SEM_BUS_V.data_product_orientation.usage_guidance|VARCHAR(500)
--CallCentre_SEM_BUS_V.data_product_orientation.is_required|BYTEINT
--CallCentre_SEM_BUS_V.data_product_orientation.discovery_order|INTEGER
--CallCentre_SEM_BUS_V.data_product_orientation.metadata_updated_at|TIMESTAMP WITH TIME ZONE

