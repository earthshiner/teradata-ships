    , session_context_json, scope_level, scope_identifier, created_at
)
/* CallCentre_MEM_BUS_V.agent_session
 * canonical view alongside friendly alias active_sessions.
 * Faithful full passthrough of CallCentre_MEM_STD_V.agent_session (all rows, all columns).
 * Consumer filter: filter by session_status as needed.
 */
AS
SELECT
      session_id, session_key, agent_key, user_key
    , session_start_dts, session_end_dts, session_status, session_goal
    , session_context_json, scope_level, scope_identifier, created_at
FROM {{CallCentre_MEM_STD_V}}.agent_session;
