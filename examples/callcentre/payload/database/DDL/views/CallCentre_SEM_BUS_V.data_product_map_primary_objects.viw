REPLACE VIEW {{CallCentre_SEM_BUS_V}}.data_product_map_primary_objects
(
    module_id
   ,database_name
   ,object_name
   ,object_type
   ,object_role
   ,usage_guidance
   ,table_kind
   ,is_active
   ,created_at
   ,updated_at
)
AS
LOCKING ROW FOR ACCESS
SELECT
    module_id
   ,database_name
   ,object_name
   ,object_type
   ,object_role
   ,usage_guidance
   ,table_kind
   ,is_active
   ,created_at
   ,updated_at
FROM {{CallCentre_SEM_STD_V}}.data_product_map_primary_objects
WHERE is_active = 1;
