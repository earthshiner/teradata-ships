CREATE MULTISET TABLE {{CallCentre_MEM_STD_T}}.agent_interaction ,FALLBACK ,
     NO BEFORE JOURNAL,
     NO AFTER JOURNAL,
     CHECKSUM = DEFAULT,
     DEFAULT MERGEBLOCKRATIO,
     MAP = TD_MAP1
     (
      interaction_id INTEGER NOT NULL GENERATED ALWAYS AS IDENTITY
           (START WITH 1
            INCREMENT BY 1
            MINVALUE -2147483647
            MAXVALUE 2147483647
            NO CYCLE),
      session_id INTEGER NOT NULL,
      interaction_seq INTEGER NOT NULL,
      interaction_type VARCHAR(50) CHARACTER SET LATIN NOT CASESPECIFIC,
      interaction_dts TIMESTAMP(6) WITH TIME ZONE NOT NULL,
      user_input VARCHAR(4000) CHARACTER SET LATIN NOT CASESPECIFIC,
      agent_response VARCHAR(4000) CHARACTER SET LATIN NOT CASESPECIFIC,
      action_taken VARCHAR(500) CHARACTER SET LATIN NOT CASESPECIFIC,
      referenced_tables VARCHAR(1000) CHARACTER SET LATIN NOT CASESPECIFIC,
      sql_executed VARCHAR(4000) CHARACTER SET LATIN NOT CASESPECIFIC,
      query_result_count INTEGER,
      execution_time_ms INTEGER,
      outcome_status VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC,
      user_feedback VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC,
      scope_level VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      scope_identifier VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC,
      created_at TIMESTAMP(6) WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP(6))
PRIMARY INDEX ( interaction_id );
