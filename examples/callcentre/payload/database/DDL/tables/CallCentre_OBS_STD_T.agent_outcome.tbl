CREATE MULTISET TABLE {{CallCentre_OBS_STD_T}}.agent_outcome ,FALLBACK ,
     NO BEFORE JOURNAL,
     NO AFTER JOURNAL,
     CHECKSUM = DEFAULT,
     DEFAULT MERGEBLOCKRATIO,
     MAP = TD_MAP1
     (
      outcome_id INTEGER NOT NULL GENERATED ALWAYS AS IDENTITY
           (START WITH 1
            INCREMENT BY 1
            MINVALUE -2147483647
            MAXVALUE 2147483647
            NO CYCLE),
      agent_key VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      session_key VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC,
      action_type VARCHAR(50) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      action_dts TIMESTAMP(6) WITH TIME ZONE NOT NULL,
      tables_accessed VARCHAR(1000) CHARACTER SET LATIN NOT CASESPECIFIC,
      outcome_status VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      user_feedback VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC,
      execution_time_ms INTEGER,
      records_processed INTEGER,
      created_at TIMESTAMP(6) WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP(6))
PRIMARY INDEX ( outcome_id );
