CREATE MULTISET TABLE {{CallCentre_MEM_STD_T}}.agent_session ,FALLBACK ,
     NO BEFORE JOURNAL,
     NO AFTER JOURNAL,
     CHECKSUM = DEFAULT,
     DEFAULT MERGEBLOCKRATIO,
     MAP = TD_MAP1
     (
      session_id INTEGER NOT NULL GENERATED ALWAYS AS IDENTITY
           (START WITH 1
            INCREMENT BY 1
            MINVALUE -2147483647
            MAXVALUE 2147483647
            NO CYCLE),
      session_key VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      agent_key VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      user_key VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC,
      session_start_dts TIMESTAMP(6) WITH TIME ZONE NOT NULL,
      session_end_dts TIMESTAMP(6) WITH TIME ZONE,
      session_status VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC,
      session_goal VARCHAR(500) CHARACTER SET LATIN NOT CASESPECIFIC,
      session_context_json JSON(16776192) INLINE LENGTH 4096 CHARACTER SET LATIN,
      scope_level VARCHAR(20) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      scope_identifier VARCHAR(100) CHARACTER SET LATIN NOT CASESPECIFIC,
      created_at TIMESTAMP(6) WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP(6))
PRIMARY INDEX ( session_id );
