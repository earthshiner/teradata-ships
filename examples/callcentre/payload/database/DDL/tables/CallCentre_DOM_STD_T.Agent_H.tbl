CREATE MULTISET TABLE {{CallCentre_DOM_STD_T}}.Agent_H ,FALLBACK ,
     NO BEFORE JOURNAL,
     NO AFTER JOURNAL,
     CHECKSUM = DEFAULT,
     DEFAULT MERGEBLOCKRATIO,
     MAP = TD_MAP1
     (
      agent_id INTEGER NOT NULL,
      agent_key VARCHAR(50) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      agent_name VARCHAR(200) CHARACTER SET LATIN NOT CASESPECIFIC NOT NULL,
      source_agent_name VARCHAR(200) CHARACTER SET LATIN NOT CASESPECIFIC,
      valid_from_dts TIMESTAMP(6) WITH TIME ZONE NOT NULL,
      valid_to_dts TIMESTAMP(6) WITH TIME ZONE NOT NULL DEFAULT TIMESTAMP '9999-12-31 23:59:59.999999+00:00',
      is_current BYTEINT NOT NULL DEFAULT 1  COMPRESS 1 ,
      is_deleted BYTEINT NOT NULL DEFAULT 0  COMPRESS 0 )
PRIMARY INDEX ( agent_id )
INDEX nusi_agent_h_name ( agent_name );