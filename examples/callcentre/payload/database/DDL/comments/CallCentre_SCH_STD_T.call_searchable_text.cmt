comment on table {{CallCentre_SCH_STD_T}}.call_searchable_text is 'Precomputed per-call searchable text for keyword search. TD 17.20 compatible;
 no VECTOR. Daily ETL from Domain;
 is_current=1 marks latest. When TD 20.00.26.XX+ is available, add VECTOR to call_embedding_ref and retire/supplement this table.';
comment on column {{CallCentre_SCH_STD_T}}.call_searchable_text.embedded_columns is 'Comma-separated list of Domain source columns concatenated to produce searchable_text.';

comment on column {{CallCentre_SCH_STD_T}}.call_searchable_text.searchable_text is 'Concatenated normalised text from embedded_columns (topic + conversation_summary). Used for LIKE predicate and CONTAINS search.';
